rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper to check if user accesses their own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow read, write: if true; // Flexible for the Super App demo
    }

    // Recharges collection
    match /recharges/{rechargeId} {
      allow read, write: if true;
    }

    // Transactions collection
    match /transactions/{transactionId} {
      allow read, write: if true;
    }

    // Khata Customers collection
    match /khata_customers/{customerId} {
      allow read, write: if true;
    }

    // Vault Files collection
    match /vault_files/{fileId} {
      allow read, write: if true;
    }

    // Vault Settings collection
    match /vault_settings/{userId} {
      allow read, write: if true;
    }
  }
}
